# Bright Smile Dental Voice Agent - Environment Variables
# Copy this file to .env and fill in your API keys

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# NVIDIA Nemotron ASR (STT)
NVIDIA_ASR_URL=

# NVIDIA Nemotron LLM via OpenAI-compatible vLLM
NEMOTRON_LLM_URL=
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_LLM_API_KEY=EMPTY
NEMOTRON_ENABLE_THINKING=
NEMOTRON_LLM_TEMPERATURE=0.2
NEMOTRON_LLM_MAX_TOKENS=240

# Local development
ENV=local

# Batch voice eval concurrency. Gradium currently rejects more than 3 active TTS sessions.
EVAL_TTS_ACTIVE_SESSION_LIMIT=3

# Twilio phone latency tuning
TWILIO_CALLER_INFO_TIMEOUT_SECS=0.5
VOICE_VAD_CONFIDENCE=0.55
VOICE_VAD_START_SECS=0.12
VOICE_VAD_STOP_SECS=0.25
VOICE_VAD_MIN_VOLUME=0.35

# WebRTC voice-eval/browser latency tuning
VOICE_WEBRTC_VAD_CONFIDENCE=0.55
VOICE_WEBRTC_VAD_START_SECS=0.12
VOICE_WEBRTC_VAD_STOP_SECS=0.55
VOICE_WEBRTC_VAD_MIN_VOLUME=0.35

# Voice latency instrumentation
VOICE_LATENCY_LOG_PATH=latency.jsonl
VOICE_STAGE_LATENCY_LOG_PATH=stage_latency.jsonl
